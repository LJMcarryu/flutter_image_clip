# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/
pubspec.lock

# Local Flutter/app metadata not needed for the package source.
.metadata
/android/local.properties

# Reference material used during the demo build; not part of the package.
/docs/

# Generated app platform folders are kept locally for demos. Only plugin
# sources required by the package are tracked.
/android/*
!/android/build.gradle
!/android/src/
!/android/src/main/
!/android/src/main/AndroidManifest.xml
!/android/src/main/kotlin/
!/android/src/main/kotlin/**
/ios/*
!/ios/Classes/
!/ios/Classes/**
!/ios/Resources/
!/ios/Resources/**
!/ios/flutter_image_clip.podspec
/linux/
/macos/
/web/
/windows/

# Generated example app platform files are local-only unless explicitly added.
/example/.gitignore
/example/README.md
/example/android/
/example/ios/
/example/linux/
/example/macos/
/example/web/
/example/windows/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release
